# SEO / GEO Article Writer environment example
# Copy this file to `.env` before starting the app.

# -------------------------------------------------------------------
# App runtime
# -------------------------------------------------------------------
# Host and port used by `start.sh` / uvicorn.
# Variable names keep the old FLASK prefix for compatibility.
FLASK_HOST=0.0.0.0
FLASK_PORT=8028
FLASK_DEBUG=true

# Local data storage directory.
# Used for cache files and generated images.
APP_DATA_DIR=./data

# Background worker count for async article tasks.
MAX_WORKERS=2

# -------------------------------------------------------------------
# Text generation
# -------------------------------------------------------------------
# `true`:
#   use local mock article output, useful for demo and development.
# `false`:
#   call the real OpenAI-compatible text model below.
LLM_MOCK_MODE=true

# OpenAI-compatible text model settings.
# Works with OpenAI, OpenRouter, Azure-compatible proxy gateways, etc.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REQUEST_TIMEOUT=90

# -------------------------------------------------------------------
# Image generation
# -------------------------------------------------------------------
# Preferred mode:
# fill `AZURE_IMAGE_API_URL` with the full Azure image generation URL.
# Example:
# https://your-endpoint.openai.azure.com/openai/deployments/gpt-image-1.5/images/generations?api-version=2024-02-01
AZURE_IMAGE_API_URL=

# Azure image generation key.
AZURE_IMAGE_API_KEY=

# Optional split config if you do not want to use the full URL above.
# When `AZURE_IMAGE_API_URL` is empty, the app can build the URL from:
#   endpoint + deployment + api version
AZURE_IMAGE_ENDPOINT=
AZURE_IMAGE_DEPLOYMENT=gpt-image-1.5
AZURE_IMAGE_API_VERSION=2025-04-01-preview

# Image output settings.
AZURE_IMAGE_SIZE=1536x1024
AZURE_IMAGE_QUALITY=medium
AZURE_IMAGE_OUTPUT_FORMAT=png

# Optional: upload generated images to Aliyun OSS.
# If the bucket is private, the app returns signed URLs.
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET=site-seo-geo-article
ALIYUN_OSS_PUBLIC_BASE_URL=https://site-seo-geo-article.oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_PREFIX=articles
ALIYUN_OSS_URL_EXPIRE_SECONDS=86400

# Default number of supporting body images used by the demo.
# Task requests can still override this with `content_image_count = 0..3`.
DEFAULT_CONTENT_IMAGE_COUNT=3

# -------------------------------------------------------------------
# Access control
# -------------------------------------------------------------------
# Step 1:
# exchange one of these access keys for a bearer token.
NORMAL_ACCESS_KEY=demo-standard-access-key
VIP_ACCESS_KEY=demo-vip-access-key

# Step 2:
# the server signs the exchanged bearer token with this secret.
# Keep it stable if you want issued tokens to remain valid across restarts.
TOKEN_SIGNING_SECRET=replace-with-a-long-random-secret

# Bearer token lifetime in seconds.
# 86400 = 1 day
TOKEN_TTL_SECONDS=86400

# -------------------------------------------------------------------
# MySQL task storage
# -------------------------------------------------------------------
# Task metadata and generated article results are persisted in MySQL.
# If MYSQL_DATABASE is empty, the app falls back to MYSQL_USER as database name.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=site-seo-geo-article
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_CHARSET=utf8mb4
MYSQL_CONNECT_TIMEOUT=10
MYSQL_READ_TIMEOUT=20
MYSQL_WRITE_TIMEOUT=20
MYSQL_RETRY_COUNT=3
MYSQL_RETRY_DELAY_SECONDS=0.6
MYSQL_POOL_SIZE=8

# If true, when MySQL is not reachable at startup, use in-memory task storage instead.
# Useful for demo availability, but tasks will not survive process restarts.
MYSQL_FALLBACK_TO_MEMORY=false

# -------------------------------------------------------------------
# Start script behavior
# -------------------------------------------------------------------
# `Y`:
#   start in background mode and write `server.pid`
# `N`:
#   start in foreground mode
IS_PROD=N

# If the target port is already occupied:
# `Y`:
#   kill the process using that port
# `N`:
#   switch to the next available port
AUTO_KILL_PORT=N
