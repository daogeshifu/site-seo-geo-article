# Docker Compose runtime settings
APP_EXPOSE_PORT=8028
MYSQL_EXPOSE_PORT=3306

# App runtime
FLASK_HOST=0.0.0.0
FLASK_PORT=8028
FLASK_DEBUG=false
APP_DATA_DIR=/app/data
MAX_WORKERS=2

# Text generation
LLM_MOCK_MODE=true
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REQUEST_TIMEOUT=90

# Image generation
AZURE_IMAGE_API_URL=
AZURE_IMAGE_API_KEY=
AZURE_IMAGE_ENDPOINT=
AZURE_IMAGE_DEPLOYMENT=gpt-image-1.5
AZURE_IMAGE_API_VERSION=2025-04-01-preview
AZURE_IMAGE_SIZE=1536x1024
AZURE_IMAGE_QUALITY=medium
AZURE_IMAGE_OUTPUT_FORMAT=png


ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET=site-seo-geo-article
ALIYUN_OSS_PUBLIC_BASE_URL=https://site-seo-geo-article.oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_PREFIX=articles
ALIYUN_OSS_URL_EXPIRE_SECONDS=86400
ALIYUN_OSS_CONNECT_TIMEOUT=10
ALIYUN_OSS_READ_TIMEOUT=180
ALIYUN_OSS_RETRY_COUNT=3
ALIYUN_OSS_RETRY_DELAY_SECONDS=1.5
DEFAULT_CONTENT_IMAGE_COUNT=3

# Access control
NORMAL_ACCESS_KEY=demo-standard-access-key
VIP_ACCESS_KEY=demo-vip-access-key
TOKEN_SIGNING_SECRET=replace-with-a-long-random-secret
TOKEN_TTL_SECONDS=86400

# MySQL settings used by both compose services and the app container
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=site-seo-geo-article
MYSQL_PASSWORD=change-this-app-password
MYSQL_DATABASE=site-seo-geo-article
MYSQL_CHARSET=utf8mb4
MYSQL_CONNECT_TIMEOUT=10
MYSQL_READ_TIMEOUT=20
MYSQL_WRITE_TIMEOUT=20
MYSQL_RETRY_COUNT=5
MYSQL_RETRY_DELAY_SECONDS=1
MYSQL_POOL_SIZE=8
MYSQL_FALLBACK_TO_MEMORY=false
